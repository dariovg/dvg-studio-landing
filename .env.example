# Copia a Vercel → Settings → Environment Variables
# No subas este archivo con valores reales a git

# --- AWS (chat Bedrock + emails SES) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# --- Chat ---
CHAT_SITE_KEY=dvg-studio-chat-2026
CHAT_ALLOWED_ORIGINS=https://dvgsstudio.com,https://www.dvgsstudio.com,https://dvgsstudio.es,https://www.dvgsstudio.es
CHAT_LIMIT_HOUR=6
CHAT_LIMIT_DAY=20
CHAT_BEDROCK_DAILY_MAX=100

# --- Contacto y booking emails ---
CONTACT_EMAIL=info@dvgsstudio.com
BOOKING_NOTIFY_EMAIL=info@dvgsstudio.com
BOOKING_FROM_EMAIL=info@dvgsstudio.com
BOOKING_MEET_URL=
BOOKING_TIMEZONE=Europe/Madrid
BOOKING_HOURS_START=9
BOOKING_HOURS_END=18
BOOKING_DURATION_MINUTES=60

# --- iCloud calendario ---
ICLOUD_CALENDAR_EMAIL=
ICLOUD_APP_PASSWORD=
ICLOUD_CALENDAR_NAME=DVG Studio

# --- Diagnóstico (/api/status?key=...) ---
DIAGNOSTIC_KEY=

# --- Google Calendar (alternativa a iCloud; no uses ambos si iCloud basta) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=
