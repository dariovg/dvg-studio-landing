# Copia a Vercel → Settings → Environment Variables
# No subas este archivo con valores reales a git

# --- AWS (chat Bedrock + emails SES) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Chat ---
CHAT_SITE_KEY=dvg-studio-chat-2026
CHAT_ALLOWED_ORIGINS=https://dvgsstudio.com,https://www.dvgsstudio.com,https://dvgsstudio.es,https://www.dvgsstudio.es
CHAT_LIMIT_HOUR=6
CHAT_LIMIT_DAY=20
# fallback = FAQ + conocimiento local; Bedrock solo si no hay match (recomendado, ~casi 0 €)
# off = nunca Bedrock | always = Bedrock en cada mensaje sin match (más caro)
CHAT_BEDROCK_MODE=fallback
# Modelo barato: nova-micro o nova-lite. Haiku cuesta varias veces más con poco beneficio aquí.
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
CHAT_BEDROCK_DAILY_MAX=40

# --- Contacto y booking emails ---
CONTACT_EMAIL=info@dvgsstudio.com
BOOKING_NOTIFY_EMAIL=info@dvgsstudio.com
BOOKING_FROM_EMAIL=info@dvgsstudio.com
# Encuesta madurez digital — por defecto https://www.dvgsstudio.com/encuesta
# DIGITALIZATION_SURVEY_URL=
BOOKING_MEET_URL=
# Meet único por cita: configura Google Calendar (abajo). BOOKING_MEET_URL solo como respaldo fijo.
BOOKING_TIMEZONE=Europe/Madrid
BOOKING_HOURS_START=9
BOOKING_HOURS_END=18
BOOKING_DURATION_MINUTES=60

# Solo estos calendarios bloquean huecos (nombres parciales, separados por coma). Vacío = todos excepto cumpleaños/festivos.
# ICLOUD_BUSY_CALENDARS=DVG Studio,Trabajo
ICLOUD_CALENDAR_EMAIL=
ICLOUD_APP_PASSWORD=
ICLOUD_CALENDAR_NAME=DVG Studio

# --- Diagnóstico (/api/status?key=...) ---
DIAGNOSTIC_KEY=

# --- Google Calendar + Gmail (citas + guía por email a clientes) ---
# OAuth debe incluir calendar.events Y gmail.send (node scripts/get-google-refresh-token.mjs).
# Sin gmail.send la guía por email falla; las citas siguen llegando vía Google Calendar.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# Invitación por email al cliente vía Google Calendar (por defecto activo). Pon 0 para desactivar.
# BOOKING_GOOGLE_SEND_UPDATES=0
